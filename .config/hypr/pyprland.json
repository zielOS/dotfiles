{
  "pyprland": {
    "plugins": [
      "scratchpads",
      "monitors",
      "workspaces_follow_focus"
    ]
  },
  "scratchpads": {
    "term": {
      "command": "alacritty --class alacritty-dropterm",
      "animation": "fromTop",
      "unfocus": "hide"
    },
        "ranger": {
            "command": "kitty --class explorer -e ranger",
            "animation": "fromBottom",
            "unfocus": "hide"
        },
    "volume": {
      "command": "pavucontrol",
      "unfocus": "hide",
      "animation": "fromRight"
    }
  },
  "monitors": {
    "placement": {
      "BenQ PJ": {
        "topOf": "eDP-1"
      }
    },
    "unknown": "wlrlui"
  }
}
