{
  "pyprland": {
    "plugins": [
      "scratchpads",
      "monitors",
      "workspaces_follow_focus"
    ]
  },
  "scratchpads": {
    "term": {
      "command": "alacritty --class alacritty-dropterm",
      "animation": "fromTop",
      "unfocus": "hide"
    },
    "ranger": {
        "command": "kitty --class explorer -e ranger",
        "animation": "fromBottom",
        "unfocus": "hide"
    },
    "file-manager": {
      "command": "thunar",
      "unfocus": "hide",
      "animation": "fromBottom"
    }
  },
  "monitors": {
    "placement": {
      "BenQ PJ": {
        "topOf": "eDP-1"
      }
    },
    "unknown": "wlrlui"
  }
}
