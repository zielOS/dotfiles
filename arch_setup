#!/bin/sh

cfdisk /dev/nvme0n1 && mkfs.vfat -F 32 /dev/nvme0n1p1 && cryptsetup --cipher aes-xts-plain64 --hash sha512 --use-random --verify-passphrase luksFormat /dev/nvme0n1p2 && cryptsetup luksOpen /dev/nvme0n1p2 root && mkfs.btrfs /dev/archlvm/root && mount /dev/archlvm/root /mnt && btrfs su cr /mnt/@  && btrfs su cr /mnt/@home && btrfs su cr /mnt/@opt  && btrfs su cr /mnt/@tmp && btrfs su cr /mnt/@var && btrfs su cr /mnt/@log && btrfs su cr /mnt/@audit && btrfs su cr /mnt/@snapshots && umount /mnt && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@ /dev/archlvm/root /mnt && mkdir /mnt/home && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@home /dev/archlvm/root /mnt/home && mkdir /mnt/opt && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@opt /dev/archlvm/root /mnt/opt  && mkdir /mnt/tmp && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@tmp /dev/archlvm/root /mnt/tmp && mkdir /mnt/var && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@var /dev/archlvm/root /mnt/var && mkdir /mnt/var/log && mount -o nmoatime,compress=zstd,space_cache=v2,discard=async,subvol=@log /dev/archlvm/root /mnt/var/log && mkdir /mnt/var/log/audit && mount -o nmoatime,compress=zstd,space_cache=v2,discard=async,subvol=@audit /dev/archlvm/root /mnt/var/log/audit && mkdir /mnt/.snapshots && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@snapshots /dev/archlvm/root /mnt/.snapshots

# systemd-boot, dracut, luks, llvm, btrfs
cfdisk /dev/nvme0n1 && mkfs.vfat -F32 /dev/nvme0n1p1 && cryptsetup --cipher aes-xts-plain64 --hash sha512 --use-random --verify-passphrase luksFormat /dev/nvme0n1p2 && cryptsetup open --perf-no_read_workqueue --perf-no_write_workqueue --persistent /dev/nvme0n1p2 cryptlvm && pvcreate /dev/mapper/cryptlvm && vgcreate archlvm /dev/mapper/cryptlvm && lvcreate -L 16G archlvm -n swap && lvcreate -l 100%FREE archlvm -n root && mkfs.btrfs -f /dev/archlvm/root && mkswap /dev/archlvm/swap

mount /dev/archlvm/root /mnt && btrfs su cr /mnt/@  && btrfs su cr /mnt/@home && btrfs su cr /mnt/@opt  && btrfs su cr /mnt/@tmp && btrfs su cr /mnt/@var && btrfs su cr /mnt/@log && btrfs su cr /mnt/@audit && btrfs su cr /mnt/@snapshots && umount /mnt && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@ /dev/archlvm/root /mnt/ && mkdir /mnt/home && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@home /dev/archlvm/root /mnt/home && mkdir /mnt/opt && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@opt /dev/archlvm/root /mnt/opt  && mkdir /mnt/tmp && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@tmp /dev/archlvm/root /mnt/tmp && mkdir /mnt//var && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@var /dev/archlvm/root /mnt/var && mkdir /mnt/var/log && mount -o nmoatime,compress=zstd,space_cache=v2,discard=async,subvol=@log /dev/archlvm/root /mnt/var/log && mkdir /mnt/var/log/audit && mount -o nmoatime,compress=zstd,space_cache=v2,discard=async,subvol=@audit /dev/archlvm/root /mnt/var/log/audit && mkdir /mnt/.snapshots && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@snapshots /dev/archlvm/root /mnt/.snapshots

#chroot into endeavoros

cryptsetup open --perf-no_read_workqueue --perf-no_write_workqueue --persistent /dev/nvme1n1p2 luks-ada46785-d1ee-4ae5-a61b-a937979c10aa && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@ /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt/ && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@home /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//home && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@opt /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//opt && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@tmp /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//tmp && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@var /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//var && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@log /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//var/log && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@audit /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//var/log/audit && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@cache /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//var/cache && mount -o noatime,compress=zstd,space_cache=v2,discard=async,subvol=@snapshots /dev/archlvm/luks-ada46785-d1ee-4ae5-a61b-a937979c10aa /mnt//.snapshots

mkdir /mnt/efi && mount /dev/nvme0n1p1 /mnt//efi

pacstrap /mnt base base-devel git neovim intel-ucode arch-install-scripts reflector dracut sbsigntools iwd efibootmgr yay sbsigntools lvm2 sbctl

genfstab -U /mnt >> /mnt/etc/fstab

arch-chroot /mnt

reflector --verbose --country 'CA,US' -l 25 --sort rate --save /etc/pacman.d/mirrorlist

## chaotic aur setup
 pacman-key --recv-key 3056513887B78AEB --keyserver keyserver.ubuntu.com && pacman-key --lsign-key 3056513887B78AEB && pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-keyring.pkg.tar.zst' &&  pacman -U 'https://cdn-mirror.chaotic.cx/chaotic-aur/chaotic-mirrorlist.pkg.tar.zst' 

nvim /etc/pacman.conf
[chaotic-aur]
Include = /etc/pacman.d/chaotic-mirrorlist 

ln -sf /usr/share/zoneinfo/Canada/Mountain /etc/localtime && hwclock --systohc && nvim /etc/locale.gen && locale-gen && echo "LANG=en_CA.UTF-8" >> /etc/locale.conf

pacman -S --noconfirm unzip zip unrar btrfs-progs chrony dosfstools thunar thunar-volman thunar-media-tags-plugin thunar-archive-plugin tumbler zathura zathura-pdf-poppler papirus-icon-theme wget curl ripgrep fd python-pip zsh zsh-completions neofetch xdg-user-dirs python-pynvim nvidia-dkms nvidia-utils mesa rng-tools haveged upower greetd greetd-tuigreet lazygit lynis firejail audit sysstat apparmor networkmanager acpid fzf flatpak fdupes ranger steam swayidle wl-clipboard kitty grim slurp wf-recorder vulkan-tools vulkan-headers vulkan-validation-layers nodejs npm rustup transmission-gtk cmake boost polkit-gnome tldr emacs-wayland snapper snap-pac

passwd && useradd -m -G users,wheel,audio,video -s /bin/bash ahsan && passwd ahsan && EDITOR=nvim visudo

# systemd-boot
bootctl install

# loader.conf
timeout 5
default arch

# entries/arch.conf
title Arch Linux
linux /vmlinuz-linux-clear
initrd /intel-ucode.img
initrd /initramfs-linux-clear.img


pacman -S dracut-hook-uefi


nvim /etc/pacman.d/hooks/998-systemd-boot.hook

[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = systemd

[Action]
Description = Updating systemd-boot
When = PostTransaction
Exec = /usr/bin/bootctl update

blkid -s UUID -o value /dev/nvme0n1p2 
993b10a7-c0d7-44a6-9123-b2eba5e65062

# dracut setup
nvim /etc/dracut.conf.d/cmdline.conf
kernel_cmdline="rd.luks.uuid=luks-993b10a7-c0d7-44a6-9123-b2eba5e65062 rd.lvm.lv=cryptlvm/root rd.lvm.lv=cryptlvm/swap resume=/dev/mapper/cryptlvm-swap  root=/dev/mapper/cryptlvm-root rootfstype=btrfs rootflags=rw"

nvim /etc/dracut.conf.d/flags.conf
compress="zstd"
hostonly="no"

nvim /etc/dracut.conf.d/force-modules.conf
force_drivers+=" btrfs nvidia nvidia_modeset nvidia_uvm nvidia_drm "

dracut --uefi --hostonly --no-hostonly-cmdline /boot/initramfs-linux-clear.img --force

reinstall-kernels

GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 cryptdevice=UUID=bec7bf34-ac4f-4ddb-92c7-b00f04858db5:root root=/dev/archlvm/root nvidia-drm.modeset=1 audit=1 lsm=landlock,lockdown,yama,integrity,apparmor,bpf  intel_iommu=igfx_off no_timer_check noreplace-smp page_alloc.shuffle=1 rcupdate.rcu_expedited=1 rootfstype=btrfs tsc=reliable rw"
GRUB_CMDLINE_LINUX=""

nvim /etc/default/grub
GRUB_CMDLINE_LINUX_DEFAULT="quiet loglevel=3 cryptdevice=UUID=c5598fbe-528d-43ab-a5ea-7b0feb11a16b:root root=/dev/archlvm/root nvidia-drm.modeset=1 lsm=landlock,lockdown,yama,integrity,apparmor,bpf"
GRUB_CMDLINE_LINUX=""

sudo grub-install --target=x86_64-efi --efi-directory=/boot && sudo grub-install --target=x86_64-efi --efi-directory=/boot --removable && sudo grub-mkconfig -o /boot/grub/grub.cfg

# refind
sudo refind-install --usedefault /dev/nvme0n1p1 --alldrivers

** Systemd Setup
systemctl enable NetworkManager fstrim.timer acpid sysstat apparmor auditd chronyd

