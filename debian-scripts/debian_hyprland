curl -fsSL https://fnm.vercel.app/install | sh
rm -R $HOME/.zshrc
ln -s $HOME/.dots/.zshrc $HOME/
chsh -s $(which zsh)

echo "git setup"
sudo nala install make gcc git libsecret-1-0 libsecret-1-dev libglib2.0-dev
sudo make --directory=/usr/share/doc/git/contrib/credential/libsecret
git config --global credential.helper /usr/share/doc/git/contrib/credential/libsecret/git-credential-libsecret
git config --global user.name "zielOS"
git config --global user.email "ahsanur041@gmail.com"

