#!/usr/bin/env bash

# Kill already running process
_ps=(waybar swayidle eww polkit-gnome-authentication-agent-1)
for _prs in "${_ps[@]}"; do
	if [[ `pidof ${_prs}` ]]; then
		killall -9 ${_prs}
	fi
done

# Idle
hypridle &

# hotkey daemon
# hyprkeys &

# wallpaper 
hyprpaper &

# theme
hyprtheme &

# polkit 
/usr/bin/lxpolkit &

wl-paste --watch cliphist store --no-newline &

# Start Apps
ckb-next &
QT_QPA_PLATFORM=xcb insync start &

thunar --daemon &

