#!/usr/bin/env bash

# Kill already running process
_ps=(waybar swayidle lxpolkit)
for _prs in "${_ps[@]}"; do
	if [[ `pidof ${_prs}` ]]; then
		killall -9 ${_prs}
	fi
done

# Idle
hypridle &

# hotkey daemon
# hyprkeys &

# wallpaper 
hyprpaper &

# theme
hyprtheme &

# plugins 
hyprctl plugin load $HOME/.config/hypr/split-monitor-workspaces.so &

# polkit 
/usr/bin/lxpolkit &

# Start Apps
ckb-next &
distrobox-enter -n aur -- insync start & 
thunar --daemon &

# aylur-gtk-shell
ags -b hypr &

pypr &

xdg-portal-hyprland &

dbus-update-activation-environment --all &
gnome-keyring-daemon -r -d &

emacs --daemon &
